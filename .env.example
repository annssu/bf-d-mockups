# =========================================================================
# BF.D 웨잇리스트 — 필요한 환경변수 (실제 값은 여기 넣지 말고 Vercel에 입력)
# -------------------------------------------------------------------------
# 이 파일은 "어떤 값이 필요한지"만 알려주는 예시예요. 실제 키는 절대 여기 X.
# 실제 값은 Vercel 대시보드 → Settings → Environment Variables 에 입력하세요.
# =========================================================================

# Supabase 프로젝트 주소 (Settings → API → Project URL)
SUPABASE_URL=https://your-project.supabase.co

# Supabase service_role 키 (Settings → API → service_role) — ⚠️ 비밀! 외부 노출 금지
SUPABASE_SERVICE_KEY=your-service-role-key

# (선택) 완료 화면 대기순번 시작 숫자. 안 넣으면 47.
WAITLIST_START_NUMBER=47
